<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title || "Edit User" %></title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
<div class="site">
  <header class="app-header">
    <div class="app-title">Edit User</div>
    <div class="app-actions">
      <a class="btn logout-btn" href="/admin/users">Back</a>
      <a class="btn logout-btn" href="/admin">Admin</a>
      <a class="btn logout-btn" href="/pos">POS</a>
    </div>
  </header>

  <div class="card" style="margin:16px;">
    <% if (error) { %>
      <p style="color:#b91c1c; font-weight:800;"><%= error %></p>
    <% } %>

    <% const p = (form && form.perms) || {}; %>
    <% const selectedRole = (form && form.role) || 'FRONT_DESK'; %>

    <form method="POST" action="/admin/users/<%= userRecord.id %>/edit">
      <div style="display:grid; gap:14px; max-width:720px;">
        <label>
          <div style="font-weight:800; margin-bottom:6px;">Username</div>
          <input name="username" value="<%= (form && form.email) || '' %>" required />
        </label>

        <label>
          <div style="font-weight:800; margin-bottom:6px;">New Password</div>
          <input type="password" name="password" placeholder="Leave blank to keep current password" />
          <div style="font-size:12px; opacity:.7; margin-top:4px;">Leave blank to keep current password</div>
        </label>

        <label>
          <div style="font-weight:800; margin-bottom:6px;">Role</div>
          <select name="role" id="roleSelect">
            <option value="FRONT_DESK" <%= selectedRole === 'FRONT_DESK' ? 'selected' : '' %>>FRONT_DESK</option>
            <option value="ADMIN" <%= selectedRole === 'ADMIN' ? 'selected' : '' %>>ADMIN</option>
          </select>
        </label>

        <label class="checkbox-inline">
          <input type="checkbox" name="isActive" <%= (form && form.isActive) ? 'checked' : '' %> />
          <span>Active</span>
        </label>

        <div id="permsBox" class="permissions-card">
          <div class="permissions-title">Permissions (<%= selectedRole %>)</div>

          <div class="permissions-grid">
            <% Object.keys(permissionLabels || {}).forEach(function(key) { %>
              <label class="perm-row">
                <input type="checkbox" name="<%= key %>" <%= p[key] ? 'checked' : '' %> />
                <span><%= permissionLabels[key] %></span>
              </label>
            <% }) %>
          </div>
        </div>

        <button class="btn logout-btn" type="submit" style="justify-self:start;">Save</button>
      </div>
    </form>
  </div>
</div>

<script>
  const roleSelect = document.getElementById('roleSelect');
  const permsBox = document.getElementById('permsBox');

  function togglePerms() {
    permsBox.style.display = roleSelect.value === 'FRONT_DESK' ? 'block' : 'none';
  }

  roleSelect.addEventListener('change', togglePerms);
  togglePerms();
</script>
<%- include('partials/footer') %>
</body>
</html>