<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Monthly Report</title>
  <link rel="stylesheet" href="/style.css" />

  <style>
    body {
      font-size: 13px;
      background: #f6f8fb;
      margin: 0;
    }

    .app-actions {
      position: relative;
      z-index: 10;
    }

    .btn-human {
      position: relative;
      z-index: 20;
      pointer-events: auto;
      padding: 10px 14px;
      border-radius: 12px;
      border: 1px solid #e5eaf2;
      background: #fff;
      color: #0f172a;
      font-weight: 800;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .btn-human:hover { background:#f8fafc; }

    .btn-primary {
      background:#0f172a;
      color:#fff;
      border-color:#0f172a;
    }

    .btn-primary:hover { opacity:.92; }

    .brand,
    .side-logo {
      pointer-events: none;
    }

    .site {
      padding: 20px;
    }

    .filter-row {
      margin-bottom: 12px;
      display:flex;
      gap:10px;
      align-items:end;
      flex-wrap:wrap;
    }

    .filter-row label {
      font-weight: 800;
      display:block;
      margin-bottom:4px;
    }

    select, input[type="date"] {
      padding:10px 12px;
      border-radius:12px;
      border:1px solid #e5eaf2;
      font-weight:700;
    }

    .report-page {
      max-width: 1100px;
      margin: 0 auto;
      background: #fff;
      padding: 20px;
      border-radius: 16px;
      box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
    }

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  padding-bottom: 12px;
  margin-bottom: 14px;
  border-bottom: 2px solid #e5e7eb;
}

.report-brand {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  flex: 1;
  min-width: 0;
}

.report-title {
  font-size: 20px;
  font-weight: 900;
  color: #0f172a;
  line-height: 1.1;
  margin: 0 0 4px 0;
}

.report-sub {
  margin-top: 0;
  color: #6b7280;
  font-size: 13px;
}

.report-meta {
  text-align: right;
  font-size: 13px;
  color: #374151;
  line-height: 1.5;
  min-width: 220px;
  flex-shrink: 0;
}

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
      margin-bottom: 20px;
    }

    .stat-box {
      background: #f8fafc;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 14px;
    }

    .stat-label {
      font-size: 12px;
      color: #6b7280;
      margin-bottom: 6px;
      font-weight: 700;
    }

    .stat-value {
      font-size: 22px;
      font-weight: 900;
      color: #111827;
    }

    .report-section {
      margin-top: 20px;
    }

    .report-section h3 {
      margin: 0 0 10px;
      font-size: 16px;
      font-weight: 900;
      color: #111827;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
    }

    table th, table td {
      padding: 10px 8px;
      border: 1px solid #e5e7eb;
      vertical-align: top;
    }

    table th {
      background: #f3f4f6;
      font-weight: 900;
    }

    .money {
      text-align: right;
      white-space: nowrap;
    }

    .report-footer {
      margin-top: 22px;
      padding-top: 12px;
      border-top: 1px solid #e5e7eb;
      text-align: center;
      font-size: 12px;
      color: #6b7280;
    }

 @media print {
  @page {
    size: A4 portrait;
    margin: 8mm;
  }

  html, body {
    margin: 0 !important;
    padding: 0 !important;
    background: #fff !important;
    height: auto !important;
  }

  .site {
    padding: 0 !important;
    margin: 0 !important;
  }

  .no-print,
  .app-header,
  .btn-human,
  form,
  .site-footer {
    display: none !important;
  }

  .report-page {
    max-width: none !important;
    margin: 0 !important;
    padding: 0 !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    background: #fff !important;
    min-height: auto !important;
  }

  .report-header,
  .report-section,
  .stats-grid,
  .report-footer {
    margin-top: 0 !important;
    margin-bottom: 8px !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }

  table {
    width: 100% !important;
  }

  table, tr, td, th {
    page-break-inside: avoid !important;
    break-inside: avoid !important;
  }
}
  </style>
</head>

<body>
  <div class="site">

    <header class="app-header no-print">
      <div class="brand"><img src="/assets/logo-ss-png.png" alt="logo" /></div>
      <div class="app-title">San Stephano Daily Access — Monthly Report</div>

      <div class="app-actions">
        <a class="btn-human" href="/pos">← Back to POS</a>
        <% if (!user || user.role === 'ADMIN' || (user.perms && user.perms.canPrintReports)) { %>
          <button
            class="btn-human btn-primary no-print"
            type="button"
            onclick="window.print(); return false;"
            style="position: relative; z-index: 20;">
            🖨️ Print Report
          </button>
        <% } %>
        <img src="/assets/job-logo-png.png" class="side-logo" alt="Job Logo" />
      </div>
    </header>

    <div class="report-page">

      <div class="report-header">
        <div class="report-brand">
          <div>
            <div class="report-title">Monthly Report</div>
            <div class="report-sub">San Stephano Daily Access</div>
          </div>
        </div>

        <div class="report-meta">
          <div><b>Range:</b> <%= from || '-' %> → <%= to || '-' %></div>
          <div><b>Printed:</b> <%= new Date().toLocaleString('en-GB') %></div>
        </div>
      </div>

      <div class="no-print" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin-bottom:12px;">
        <a class="btn-human btn-primary"
           href="/reports/monthly/export.xlsx<%= (from || to) ? ('?from=' + encodeURIComponent(from || '') + '&to=' + encodeURIComponent(to || '')) : '' %>">
          ⬇️ Export Excel
        </a>

        <button class="btn-human btn-primary" type="button" id="printReportBtn">
          🖨️ Print Report
        </button>

        <a class="btn-human" href="/reports/monthly">Reset</a>
      </div>

      <form class="filter-row no-print" id="filterForm" method="get" action="/reports/monthly">
        <div>
          <label>Quick Filter</label>
          <select id="preset" name="preset">
            <option value="">Select…</option>
            <option value="today">Today</option>
            <option value="week">This Week</option>
            <option value="month">This Month</option>
            <option value="lastMonth">Last Month</option>
            <option value="custom">Custom Range</option>
          </select>
        </div>

        <div>
          <label>From</label>
          <input type="date" id="from" name="from" value="<%= from || '' %>" />
        </div>

        <div>
          <label>To</label>
          <input type="date" id="to" name="to" value="<%= to || '' %>" />
        </div>

        <div>
          <button type="submit" class="btn-human btn-primary">Apply Filter ✅</button>
        </div>
      </form>

      <div id="print-area">
        <div class="stats-grid">
          <div class="stat-box">
            <div class="stat-label">From</div>
            <div class="stat-value" style="font-size:18px;"><%= from || '-' %></div>
          </div>
          <div class="stat-box">
            <div class="stat-label">To</div>
            <div class="stat-value" style="font-size:18px;"><%= to || '-' %></div>
          </div>
          <div class="stat-box">
            <div class="stat-label">Total Sales</div>
            <div class="stat-value">$<%= (total || 0).toFixed(2) %></div>
          </div>
        </div>

        <div class="report-section">
          <h3>Invoice Lines</h3>
          <table>
            <thead>
              <tr>
                <th>Invoice #</th>
                <th>Category</th>
                <th style="text-align:center">Qty</th>
                <th class="money">Amount</th>
              </tr>
            </thead>
            <tbody>
              <% (rows || []).forEach(function(r){ %>
                <tr>
                  <td><%= r.invoiceNumber != null ? r.invoiceNumber : '-' %></td>
                  <td><%= (r.category || '').replaceAll('_',' ') %></td>
                  <td style="text-align:center"><%= r.qty || 0 %></td>
                  <td class="money">$<%= (r.total || 0).toFixed(2) %></td>
                </tr>
              <% }) %>
              <% if(!rows || rows.length === 0){ %>
                <tr><td colspan="4">No sales in this date range.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="report-section">
          <h3>Summary by Category</h3>
          <table>
            <thead>
              <tr>
                <th>Category</th>
                <th>Quantity</th>
                <th class="money">Total</th>
              </tr>
            </thead>
            <tbody>
              <% (grouped || []).forEach(function(g){ %>
                <tr>
                  <td><%= (g.category || '').replaceAll('_',' ') %></td>
                  <td><%= g.qty %></td>
                  <td class="money">$<%= (g.total || 0).toFixed(2) %></td>
                </tr>
              <% }) %>
              <% if(!grouped || grouped.length === 0){ %>
                <tr><td colspan="3">No data.</td></tr>
              <% } %>
            </tbody>
            <tfoot>
              <tr>
                <td colspan="2" style="text-align:right;font-weight:900">Total Sales</td>
                <td class="money" style="font-weight:900">$<%= (total || 0).toFixed(2) %></td>
              </tr>
            </tfoot>
          </table>
        </div>

        <div class="report-footer">
          San Stephano Daily Access — Monthly Report
        </div>
      </div>

    </div>
  </div>

  <script>
    function toISODate(d){
      const x = new Date(d);
      const yyyy = x.getFullYear();
      const mm = String(x.getMonth()+1).padStart(2,'0');
      const dd = String(x.getDate()).padStart(2,'0');
      return `${yyyy}-${mm}-${dd}`;
    }

    function startOfWeek(d){
      const x = new Date(d);
      const day = x.getDay();
      const diff = (day === 0 ? 6 : day - 1);
      x.setDate(x.getDate() - diff);
      x.setHours(0,0,0,0);
      return x;
    }

    function endOfWeek(d){
      const s = startOfWeek(d);
      const e = new Date(s);
      e.setDate(e.getDate() + 6);
      return e;
    }

    function startOfMonth(d){ return new Date(d.getFullYear(), d.getMonth(), 1); }
    function endOfMonth(d){ return new Date(d.getFullYear(), d.getMonth() + 1, 0); }

    const preset = document.getElementById('preset');
    const fromEl = document.getElementById('from');
    const toEl = document.getElementById('to');

    function applyPreset(val){
      const now = new Date();

      if(val === 'today'){
        fromEl.value = toISODate(now);
        toEl.value = toISODate(now);
      } else if(val === 'week'){
        fromEl.value = toISODate(startOfWeek(now));
        toEl.value = toISODate(endOfWeek(now));
      } else if(val === 'month'){
        fromEl.value = toISODate(startOfMonth(now));
        toEl.value = toISODate(endOfMonth(now));
      } else if(val === 'lastMonth'){
        const last = new Date(now.getFullYear(), now.getMonth() - 1, 1);
        fromEl.value = toISODate(startOfMonth(last));
        toEl.value = toISODate(endOfMonth(last));
      }
    }

    if (preset && fromEl && toEl) {
      preset.addEventListener('change', (e)=> applyPreset(e.target.value));

      if(!fromEl.value && !toEl.value){
        preset.value = 'month';
        applyPreset('month');
      } else {
        preset.value = 'custom';
      }
    }
  </script>

  <%- include('partials/footer') %>
  <script>
    const printBtn = document.getElementById('printReportBtn');
    if (printBtn) {
      printBtn.addEventListener('click', function () {
        window.print();
      });
    }
  </script>
</body>
</html>