<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= title || "Voided Invoices" %></title>
  <link rel="stylesheet" href="/style.css" />

  <style>
    body {
      font-size: 13px;
      background: #f6f8fb;
      margin: 0;
    }

    .app-actions {
      position: relative;
      z-index: 10;
    }

    .btn-human {
      position: relative;
      z-index: 20;
      pointer-events: auto;
      padding: 10px 14px;
      border-radius: 12px;
      border: 1px solid #e5eaf2;
      background: #fff;
      color: #0f172a;
      font-weight: 800;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .btn-human:hover { background:#f8fafc; }

    .btn-primary {
      background:#0f172a;
      color:#fff;
      border-color:#0f172a;
    }

    .btn-primary:hover { opacity:.92; }

    .brand,
    .side-logo {
      pointer-events: none;
    }

    .site {
      padding: 20px;
    }

    .filter-row {
      margin-bottom: 12px;
      display:flex;
      gap:10px;
      align-items:end;
      flex-wrap:wrap;
    }

    .filter-row label {
      font-weight:800;
      display:block;
      margin-bottom:4px;
    }

    input[type="date"] {
      padding:10px 12px;
      border-radius:12px;
      border:1px solid #e5eaf2;
      font-weight:700;
    }

.report-page {
  max-width: 1100px;
  margin: 0 auto;
  background: #fff;
  padding: 20px;
  border-radius: 16px;
  box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
}

  .report-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  padding-bottom: 12px;
  margin-bottom: 14px;
  border-bottom: 2px solid #e5e7eb;
}

.report-brand {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  flex: 1;
  min-width: 0;
}

.report-title {
  font-size: 20px;
  font-weight: 900;
  color: #0f172a;
  line-height: 1.1;
  margin: 0 0 4px 0;
}

.report-sub {
  margin-top: 0;
  color: #6b7280;
  font-size: 13px;
}

.report-meta {
  text-align: right;
  font-size: 13px;
  color: #374151;
  line-height: 1.5;
  min-width: 220px;
  flex-shrink: 0;
}

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      margin-bottom: 20px;
    }

    .stat-box {
      background: #f8fafc;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 14px;
    }

    .stat-label {
      font-size: 12px;
      color: #6b7280;
      margin-bottom: 6px;
      font-weight: 700;
    }

    .stat-value {
      font-size: 22px;
      font-weight: 900;
      color: #111827;
    }

    .report-section {
      margin-top: 20px;
    }

    .report-section h3 {
      margin: 0 0 10px;
      font-size: 16px;
      font-weight: 900;
      color: #111827;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
    }

    table th, table td {
      padding: 10px 8px;
      border: 1px solid #e5e7eb;
      vertical-align: top;
    }

    table th {
      background: #f3f4f6;
      font-weight: 900;
    }

    .money {
      text-align: right;
      white-space: nowrap;
    }

    .report-footer {
      margin-top: 22px;
      padding-top: 12px;
      border-top: 1px solid #e5e7eb;
      text-align: center;
      font-size: 12px;
      color: #6b7280;
    }

 @media print {
  @page {
    size: A4 portrait;
    margin: 8mm;
  }

  html, body {
    margin: 0 !important;
    padding: 0 !important;
    background: #fff !important;
    height: auto !important;
  }

  .site {
    padding: 0 !important;
    margin: 0 !important;
  }

  .no-print,
  .app-header,
  .btn-human,
  form,
  .site-footer {
    display: none !important;
  }

  .report-page {
    max-width: none !important;
    margin: 0 !important;
    padding: 0 !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    background: #fff !important;
    min-height: auto !important;
  }

  .report-header,
  .report-section,
  .stats-grid,
  .report-footer {
    margin-top: 0 !important;
    margin-bottom: 8px !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }

  table {
    width: 100% !important;
  }

  table, tr, td, th {
    page-break-inside: avoid !important;
    break-inside: avoid !important;
  }
}
  </style>
</head>
<body>
  <div class="site">

    <header class="app-header no-print">
      <div class="brand"><img src="/assets/logo-ss-png.png" alt="logo" /></div>
      <div class="app-title">San Stephano Daily Access — Voided Invoices</div>

      <div class="app-actions">
        <a class="btn-human" href="/pos">← Back to POS</a>
        <% if (!user || user.role === 'ADMIN' || (user.perms && user.perms.canPrintReports)) { %>
          <button
            class="btn-human btn-primary no-print"
            type="button"
            onclick="window.print(); return false;"
            style="position: relative; z-index: 20;">
            🖨️ Print Report
          </button>
        <% } %>
        <img src="/assets/job-logo-png.png" class="side-logo" alt="Job Logo" />
      </div>
    </header>

    <div class="report-page">

      <div class="report-header">
        <div class="report-brand">

          <div>
            <div class="report-title">Voided Invoices</div>
            <div class="report-sub">San Stephano Daily Access</div>
          </div>
        </div>

        <div class="report-meta">
          <div><b>Range:</b> <%= from || '-' %> → <%= to || '-' %></div>
          <div><b>Printed:</b> <%= new Date().toLocaleString('en-GB') %></div>
        </div>
      </div>

      <% if (message) { %>
        <p style="color:#b91c1c; font-weight:800;"><%= message %></p>
      <% } %>

      <div class="no-print" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin-bottom:12px;">
        <a class="btn-human btn-primary"
           href="/reports/voided/export.xlsx<%= (from || to) ? ('?from=' + encodeURIComponent(from || '') + '&to=' + encodeURIComponent(to || '')) : '' %>">
          ⬇️ Export Excel
        </a>

        <button class="btn-human btn-primary" type="button" id="printReportBtn">
          🖨️ Print Report
        </button>

        <a class="btn-human" href="/reports/voided">Reset</a>
      </div>

      <form class="filter-row no-print" method="get" action="/reports/voided">
        <div>
          <label>From</label>
          <input type="date" name="from" value="<%= from || '' %>" />
        </div>
        <div>
          <label>To</label>
          <input type="date" name="to" value="<%= to || '' %>" />
        </div>
        <div>
          <button type="submit" class="btn-human btn-primary">Apply Filter ✅</button>
        </div>
      </form>

      <div id="print-area">
        <div class="stats-grid">
          <div class="stat-box">
            <div class="stat-label">Voided Invoices</div>
            <div class="stat-value"><%= countInvoices || 0 %></div>
          </div>
          <div class="stat-box">
            <div class="stat-label">Total Amount</div>
            <div class="stat-value">
  $<%= Number(
    (rows || []).reduce((sum, r) => {
      const lineTotal = (r.total && r.total > 0) ? r.total : ((r.qty || 0) * (r.price || 0));
      return sum + Number(lineTotal || 0);
    }, 0)
  ).toFixed(2) %>
</div>
          </div>
        </div>

        <div class="report-section">
          <h3>Invoice Lines (VOIDED)</h3>
          <table>
            <thead>
  <tr>
    <th>Invoice #</th>
    <th>Voided At</th>
    <th>Voided By</th>
    <th>Category</th>
    <th style="text-align:center">Qty</th>
    <th class="money">Price</th>
    <th class="money">Total</th>
    <th>Reason</th>
  </tr>
</thead>
    <tbody>
  <% (rows || []).forEach(function(r){ %>
    <tr>
      <td><%= r.invoiceNumber != null ? r.invoiceNumber : '-' %></td>
      <td><%= r.voidedAt ? new Date(r.voidedAt).toLocaleString('en-GB') : '-' %></td>
      <td><%= r.voidedByName || '-' %></td>
      <td><%= (r.category || '').replaceAll('_',' ') %></td>
      <td style="text-align:center"><%= r.qty || 0 %></td>
      <td class="money">$<%= Number(r.price || 0).toFixed(2) %></td>
      <td class="money">$<%= Number((r.total && r.total > 0) ? r.total : ((r.qty || 0) * (r.price || 0))).toFixed(2) %></td>
      <td style="white-space:pre-wrap;"><%= r.voidReason || '' %></td>
    </tr>
  <% }) %>

  <% if(!rows || rows.length === 0){ %>
    <tr><td colspan="8">No voided invoices in this range.</td></tr>
  <% } %>
</tbody>
          </table>
        </div>

        <div class="report-section">
          <h3>Summary by Category (VOIDED)</h3>
          <table>
            <thead>
              <tr>
                <th>Category</th>
                <th>Quantity</th>
                <th class="money">Total</th>
              </tr>
            </thead>
            <tbody>
              <% (grouped || []).forEach(function(g){ %>
                <tr>
                  <td><%= (g.category || '').replaceAll('_',' ') %></td>
                  <td><%= g.qty %></td>
                  <td class="money">$<%= (g.total || 0).toFixed(2) %></td>
                </tr>
              <% }) %>
              <% if(!grouped || grouped.length === 0){ %>
                <tr><td colspan="3">No data.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="report-footer">
          San Stephano Daily Access — Voided Invoices
        </div>
      </div>

    </div>
  </div>

  <%- include('partials/footer') %>
  <script>
    const printBtn = document.getElementById('printReportBtn');
    if (printBtn) {
      printBtn.addEventListener('click', function () {
        window.print();
      });
    }
  </script>
</body>
</html>