<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title || "Users" %></title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
<div class="site">
  <header class="app-header">
    <div class="app-title">Users</div>
    <div class="app-actions">
      <a class="btn primary" href="/admin/users/new">+ New User</a>
      <a class="btn" href="/admin">Back</a>
      <a class="btn" href="/pos">POS</a>
    </div>
  </header>

  <div class="card" style="margin:16px; overflow:auto;">
    <% if (message) { %>
      <p style="color:#b91c1c; font-weight:800;"><%= message %></p>
    <% } %>

    <form method="GET" action="/admin/users" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin-bottom:12px;">
      <input name="q" placeholder="Search email..." value="<%= q || '' %>" style="max-width:320px;" />
      <button class="btn" type="submit">Search</button>
      <a class="btn" href="/admin/users">Clear</a>
    </form>

<table class="table">
  <thead>
    <tr>
      <th>Email</th>
      <th>Role</th>
      <th>Access</th>
      <th>Status</th>
      <th>Created</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (users && users.length) { %>
      <% users.forEach(function(u) { %>
        <tr>
          <td><%= u.email || u.username || '-' %></td>
          <td><%= u.role || '-' %></td>
          <td>
            <% if ((u.role || '').toUpperCase().includes('ADMIN')) { %>
              <span class="badge on">Full Access</span>
            <% } else { %>
              <span class="badge">Custom Permissions</span>
            <% } %>
          </td>
          <td>
            <% if (u.active || u.isActive) { %>
              <span class="badge on">Active</span>
            <% } else { %>
              <span class="badge off">Inactive</span>
            <% } %>
          </td>
          <td><%= u.createdAt ? new Date(u.createdAt).toLocaleString('en-GB') : '-' %></td>
          <td>
            <div style="display:flex; gap:8px; flex-wrap:wrap;">
              <a class="btn" href="/admin/users/<%= u.id %>/edit">Edit</a>

              <form method="POST" action="/admin/users/<%= u.id %>/toggle" style="display:inline;">
                <button class="btn success" type="submit">
                  <%= (u.active || u.isActive) ? 'Deactivate' : 'Activate' %>
                </button>
              </form>

              <form
                method="POST"
                action="/admin/users/<%= u.id %>/delete"
                style="display:inline;"
                onsubmit='return confirm("Delete this user?");'
              >
                <button class="btn danger" type="submit">Delete</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
    <% } else { %>
      <tr>
        <td colspan="6" style="text-align:center; padding:16px;">No users found</td>
      </tr>
    <% } %>
  </tbody>
</table>
  </div>
</div>
<%- include('partials/footer') %>
</body>
</html>